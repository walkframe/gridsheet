{
  "name": "@gridsheet/react-dev",
  "version": "3.0.1",
  "description": "Development tools for GridSheet",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist || true && vite build",
    "typecheck": "pnpm tsc --noEmit"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/gridsheet.git"
  },
  "bugs": {
    "url": "https://github.com/walkframe/gridsheet/issues"
  },
  "homepage": "https://gridsheet.walkframe.com/",
  "packageManager": "pnpm@10.6.5",
  "peerDependencies": {
    "@gridsheet/core": "3.0.1",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "devDependencies": {
    "@gridsheet/core": "workspace:*",
    "@types/react": "^16.9.24",
    "@types/react-dom": "^16.9.24",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "react-syntax-highlighter": "^16.1.1"
  }
}
