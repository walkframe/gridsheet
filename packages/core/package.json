{
  "name": "@gridsheet/core",
  "version": "3.0.0-rc.11",
  "description": "Framework-agnostic core for gridsheet (Sheet, Registry, formula engine, etc.)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist || true && vite build",
    "less": "lessc --clean-css ./src/styles/root.less ./src/styles/root.min.css",
    "generate-style": "node ./src/generate-style.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/gridsheet.git"
  },
  "keywords": [
    "spreadsheet",
    "spread-sheet",
    "excel"
  ],
  "author": "righ",
  "license": "Apache-2.0",
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/walkframe/gridsheet/issues"
  },
  "homepage": "https://gridsheet.walkframe.com/",
  "packageManager": "pnpm@10.6.5",
  "devDependencies": {
    "less": "^4.1.3",
    "less-plugin-clean-css": "^1.5.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "dependencies": {
    "dayjs": "^1.11.13"
  },
  "publishConfig": {
    "access": "public"
  }
}
