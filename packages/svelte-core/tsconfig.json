{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "paths": {
      "@gridsheet/preact-core": ["../preact-core/dist"],
      "@gridsheet/preact-core/spellbook": ["../preact-core/dist/spellbook"],
      "@gridsheet/functions": ["../functions/dist"]
    }
  },
  "include": ["src"]
}
