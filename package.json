{
  "name": "@gridsheet/root",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "cd packages/storybook && pnpm dev",
    "doc": "cd packages/docs && pnpm dev",
    "build:react-core": "cd packages/react-core && pnpm build --mode development",
    "build:react-dev": "cd packages/react-dev && pnpm build --mode development",
    "build:preact-core": "cd packages/preact-core && pnpm build",
    "build:functions": "cd packages/functions && pnpm build",
    "build:core": "cd packages/core && pnpm build",
    "build:all": "pnpm build:core && pnpm build:react-core && pnpm build:react-dev && pnpm build:preact-core && pnpm build:functions",
    "typecheck:react-core": "cd packages/react-core && pnpm typecheck",
    "typecheck:all": "pnpm typecheck:react-core",
    "generate-style": "cd packages/core && pnpm generate-style",
    "e2e": "cd e2e && npx playwright test -c playwright.config.ts --workers 4",
    "jest:functions": "cd packages/functions && pnpm jest",
    "jest": "pnpm jest:functions",
    "test": "pnpm jest && pnpm e2e",
    "prettier": "prettier --write '**/*.{ts,tsx}'",
    "clean:cache": "rm -rf packages/storybook/node_modules/.cache/storybook",
    "clean": "pnpm store prune && rm -rf node_modules packages/*/node_modules packages/*/.cache packages/*/dist",
    "clean:install": "pnpm clean && pnpm install",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:fix": "pnpm eslint --fix --ext .ts,.tsx . && pnpm prettier",
    "remove:root": "rm -rf node_modules",
    "remove:react-core": "cd packages/react-core && rm -rf node_modules",
    "remove:react-dev": "cd packages/react-dev && rm -rf node_modules",
    "remove:preact-core": "cd packages/preact-core && rm -rf node_modules",
    "remove:functions": "cd packages/functions && rm -rf node_modules",
    "remove:storybook": "cd packages/storybook && rm -rf node_modules",
    "remove:docs": "cd packages/docs && rm -rf node_modules",
    "remove:core": "cd packages/core && rm -rf node_modules",
    "remove:all": "pnpm remove:core && pnpm remove:react-core && pnpm remove:react-dev && pnpm remove:preact-core && pnpm remove:storybook && pnpm remove:docs && pnpm remove:functions",
    "install:root": "pnpm install",
    "install:react-core": "cd packages/react-core && pnpm install",
    "install:react-dev": "cd packages/react-dev && pnpm install",
    "install:preact-core": "cd packages/preact-core && pnpm install",
    "install:functions": "cd packages/functions && pnpm install",
    "install:storybook": "cd packages/storybook && pnpm install",
    "install:docs": "cd packages/docs && pnpm install",
    "install:core": "cd packages/core && pnpm install",
    "install:all": "pnpm install:core && pnpm install:react-core && pnpm install:react-dev && pnpm install:preact-core && pnpm install:functions && pnpm install:storybook && pnpm install:docs",
    "reset:all": "pnpm remove:all && pnpm install:all && pnpm build:all && pnpm clean:cache"
  },
  "resolutions": {
    "react": "18.2.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0"
  }
}